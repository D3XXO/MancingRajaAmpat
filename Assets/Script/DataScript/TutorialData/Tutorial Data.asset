%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e68170ed1968aec4ba1be55612a6a1f7, type: 3}
  m_Name: Tutorial Data
  m_EditorClassIdentifier: 
  steps:
  - sentence: 'Halo, Penjelajah!

      Selamat datang di surga dunia, kepulauan
      Raja Ampat Indonesia!'
    characterSprite: {fileID: 1751235890, guid: c538ff57c18627a4eafe3e9c661704a4, type: 3}
    tutorialImage: {fileID: 0}
    fishingTutorImage: {fileID: 0}
  - sentence: Kita akan menjelajah perairan ini untuk menemukan berbagai jenis spesies
      ikan dan melengkapi ensiklopedia.
    characterSprite: {fileID: 1751235890, guid: c538ff57c18627a4eafe3e9c661704a4, type: 3}
    tutorialImage: {fileID: 0}
    fishingTutorImage: {fileID: 0}
  - sentence: Perairan Raja Ampat sangat luas! Kita harus mendayung perahu untuk
      mencari spot pancing yang tersebar di sepanjang lautan.
    characterSprite: {fileID: 1751235890, guid: c538ff57c18627a4eafe3e9c661704a4, type: 3}
    tutorialImage: {fileID: 0}
    fishingTutorImage: {fileID: 0}
  - sentence: Tekan tombol kanan untuk mendayung ke arah kanan.
    characterSprite: {fileID: 669661150, guid: c538ff57c18627a4eafe3e9c661704a4, type: 3}
    tutorialImage: {fileID: 21300000, guid: 42420e738a234034d803605ce5b28f45, type: 3}
    fishingTutorImage: {fileID: 0}
  - sentence: Dan tombol kiri untuk mendayung sebaliknya.
    characterSprite: {fileID: 669661150, guid: c538ff57c18627a4eafe3e9c661704a4, type: 3}
    tutorialImage: {fileID: 21300000, guid: 14b046d22e8854149ab06ef10c2fe283, type: 3}
    fishingTutorImage: {fileID: 0}
  - sentence: Dan... Jika kamu melihat sampah, tolong diambil ya!
    characterSprite: {fileID: 669661150, guid: c538ff57c18627a4eafe3e9c661704a4, type: 3}
    tutorialImage: {fileID: 21300000, guid: 995a748e25f26d4458602cd6eb103c8d, type: 3}
    fishingTutorImage: {fileID: 0}
  - sentence: Jadi jangan lupa untuk tetap menjaga kebersihan surga dunia ini.
    characterSprite: {fileID: 669661150, guid: c538ff57c18627a4eafe3e9c661704a4, type: 3}
    tutorialImage: {fileID: 0}
    fishingTutorImage: {fileID: 0}
  - sentence: Oh ya! Kamu tidak sendirian di laut, nanti kita akan berpapasan dengan
      beberapa penduduk lokal.
    characterSprite: {fileID: 1751235890, guid: c538ff57c18627a4eafe3e9c661704a4, type: 3}
    tutorialImage: {fileID: 0}
    fishingTutorImage: {fileID: 0}
  - sentence: Dekati mereka dan klik tombol interaksi untuk menyapa dan mengobrol
      santai bersama mereka.
    characterSprite: {fileID: 1751235890, guid: c538ff57c18627a4eafe3e9c661704a4, type: 3}
    tutorialImage: {fileID: 21300000, guid: 8cdcbc8ac21f14b43a2f273ad31d89df, type: 3}
    fishingTutorImage: {fileID: 0}
  - sentence: Lalu jika nanti kita masuk spot mancing, kamu bisa memancing dengan
      bermain ritem game.
    characterSprite: {fileID: 669661150, guid: c538ff57c18627a4eafe3e9c661704a4, type: 3}
    tutorialImage: {fileID: 21300000, guid: a042ba23bbc707e4db720e7f6546be77, type: 3}
    fishingTutorImage: {fileID: 0}
  - sentence: 'Ritem game 1, namanya Ritem Flow.

      Kamu harus menekan tombol
      yang sesuai dengan note tepat pada lingkaran putih.'
    characterSprite: {fileID: 1751235890, guid: c538ff57c18627a4eafe3e9c661704a4, type: 3}
    tutorialImage: {fileID: 0}
    fishingTutorImage: {fileID: 21300000, guid: f83738eb612ff334dacc174008463b02, type: 3}
  - sentence: 'Ritem game 2, namanya Ritem TapTap.

      Kamu harus menekan note
      yang muncul di layar sebelum dia menyusut dan menghilang.'
    characterSprite: {fileID: 1751235890, guid: c538ff57c18627a4eafe3e9c661704a4, type: 3}
    tutorialImage: {fileID: 0}
    fishingTutorImage: {fileID: 21300000, guid: 11d82f8211aee0f469f0ef158365dab6, type: 3}
  - sentence: Hati-hati ya dalam memancing! Karena jika kamu gagal, maka skor yang
      kamu miliki akan diambil <color=red>sepersepuluh.</color>
    characterSprite: {fileID: 1751235890, guid: c538ff57c18627a4eafe3e9c661704a4, type: 3}
    tutorialImage: {fileID: 0}
    fishingTutorImage: {fileID: 0}
  - sentence: Kamu juga bisa membuka menu ensiklopedia kapan saja melalui tombol
      buku untuk melihat ikan yang sudah kamu tangkap.
    characterSprite: {fileID: 669661150, guid: c538ff57c18627a4eafe3e9c661704a4, type: 3}
    tutorialImage: {fileID: 21300000, guid: bbfc41b47663e5645a1215cdb31ecedd, type: 3}
    fishingTutorImage: {fileID: 0}
  - sentence: Nah, kemudian ada hal seru di dalam menu Ensiklopedia, kamu bisa merekam
      suaramu sendiri untuk setiap ikan loh.
    characterSprite: {fileID: 669661150, guid: c538ff57c18627a4eafe3e9c661704a4, type: 3}
    tutorialImage: {fileID: 21300000, guid: d6c93d89a87b3c341af3da490f6a5579, type: 3}
    fishingTutorImage: {fileID: 0}
  - sentence: Jika sudah merekam, suaramu akan otomatis terputar setiap kali ikan
      tersebut berhasil tertangkap.
    characterSprite: {fileID: 669661150, guid: c538ff57c18627a4eafe3e9c661704a4, type: 3}
    tutorialImage: {fileID: 0}
    fishingTutorImage: {fileID: 0}
  - sentence: 'Lalu, jangan lupa jalan pulang ya.

      Kamu bisa klik tombol rumah
      untuk langsung teleportasi ke tempat awal.'
    characterSprite: {fileID: 669661150, guid: c538ff57c18627a4eafe3e9c661704a4, type: 3}
    tutorialImage: {fileID: 21300000, guid: 26ff3dccaddc40e4da70719bceaa84e8, type: 3}
    fishingTutorImage: {fileID: 0}
  - sentence: Sekarang mari berpetualang, Penjelajah!
    characterSprite: {fileID: 669661150, guid: c538ff57c18627a4eafe3e9c661704a4, type: 3}
    tutorialImage: {fileID: 0}
    fishingTutorImage: {fileID: 0}
