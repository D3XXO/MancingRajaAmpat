%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f0aa73c25086ea9499625e6b3ef777a6, type: 3}
  m_Name: NPC4
  m_EditorClassIdentifier: 
  dialogueGroups:
  - topicName: Sapaan
    lines:
    - characterName: Kaka Lince
      sentence: Malam, Penjelajah! Ko tra takut kah sendirian di tengah laut luas?
      characterSprite: {fileID: -578320663, guid: 845496b3d6213ea4f94ea3d0c51351ab, type: 3}
    - characterName: ' '
      sentence: Halo Kaka Lince. Awalnya takut, tapi pemandangannya bikin tenang.
      characterSprite: {fileID: 1751235890, guid: c538ff57c18627a4eafe3e9c661704a4, type: 3}
    - characterName: Kaka Lince
      sentence: Bagus! Laut ini kawan kalau tong sopan sama dia.
      characterSprite: {fileID: -578320663, guid: 845496b3d6213ea4f94ea3d0c51351ab, type: 3}
    - characterName: ' '
      sentence: Ternyata banyak juga ya nelayan perempuan di sini.
      characterSprite: {fileID: 669661150, guid: c538ff57c18627a4eafe3e9c661704a4, type: 3}
    - characterName: Kaka Lince
      sentence: Hau! Perempuan Papua itu tangguh, Kaka. Laut tra pilih kasih soal
        gender.
      characterSprite: {fileID: -578320663, guid: 845496b3d6213ea4f94ea3d0c51351ab, type: 3}
  - topicName: Tradisi Sasi
    lines:
    - characterName: ' '
      sentence: Kaka Lince, saya dengar ada area laut yang dilarang dipancing?
      characterSprite: {fileID: 1751235890, guid: c538ff57c18627a4eafe3e9c661704a4, type: 3}
    - characterName: Kaka Lince
      sentence: Oh, itu namanya wilayah Sasi, Kaka. Adat yang larang tong ambil hasil
        laut di situ.
      characterSprite: {fileID: -578320663, guid: 845496b3d6213ea4f94ea3d0c51351ab, type: 3}
    - characterName: ' '
      sentence: Supaya apa, Kaka?
      characterSprite: {fileID: 669661150, guid: c538ff57c18627a4eafe3e9c661704a4, type: 3}
    - characterName: Kaka Lince
      sentence: Supaya alam bisa istirahat. Nanti ada waktunya baru tong buka dan
        panen sama-sama.
      characterSprite: {fileID: -578320663, guid: 845496b3d6213ea4f94ea3d0c51351ab, type: 3}
    - characterName: ' '
      sentence: Keren sekali, adat bisa menjaga kelestarian alam ya.
      characterSprite: {fileID: 1751235890, guid: c538ff57c18627a4eafe3e9c661704a4, type: 3}
    - characterName: Kaka Lince
      sentence: Iyo. Adat itu cara leluhur bicara supaya tong tra serakah.
      characterSprite: {fileID: -578320663, guid: 845496b3d6213ea4f94ea3d0c51351ab, type: 3}
  - topicName: Burung Cendrawasih
    lines:
    - characterName: Kaka Lince
      sentence: Kalau pagi hari, ko bisa dengar suara Burung Cendrawasih dari arah
        hutan.
      characterSprite: {fileID: -578320663, guid: 845496b3d6213ea4f94ea3d0c51351ab, type: 3}
    - characterName: ' '
      sentence: Wah, saya sangat ingin melihat burung surga itu.
      characterSprite: {fileID: 669661150, guid: c538ff57c18627a4eafe3e9c661704a4, type: 3}
    - characterName: Kaka Lince
      sentence: Dong itu permata tanah Papua. Harus jaga hutan supaya dong tetap
        menari.
      characterSprite: {fileID: -578320663, guid: 845496b3d6213ea4f94ea3d0c51351ab, type: 3}
    - characterName: ' '
      sentence: Ikan di laut dijaga, burung di hutan juga dijaga ya.
      characterSprite: {fileID: 1751235890, guid: c538ff57c18627a4eafe3e9c661704a4, type: 3}
    - characterName: Kaka Lince
      sentence: Betul. Semua itu satu nafas, Kaka. Tra boleh ada yang rusak.
      characterSprite: {fileID: -578320663, guid: 845496b3d6213ea4f94ea3d0c51351ab, type: 3}
