%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f0aa73c25086ea9499625e6b3ef777a6, type: 3}
  m_Name: NPC3
  m_EditorClassIdentifier: 
  dialogueGroups:
  - topicName: Welcome
    lines:
    - characterName: Pace
      sentence: Selamat datang di surga kecil, Kaka! Bagaimana? Mata su segar lihat
        air biru begini?
      characterSprite: {fileID: -1062341636, guid: 42405165cf4950b4a8f837426235b79f, type: 3}
    - characterName: ' '
      sentence: Luar biasa, Pace. Saya belum pernah lihat air sejernih ini sebelumnya.
      characterSprite: {fileID: 1751235890, guid: c538ff57c18627a4eafe3e9c661704a4, type: 3}
    - characterName: Pace
      sentence: Iyo to! Orang bilang ini jatuhannya potongan surga. Ko harus keliling
        sampai ke Wayag sana.
      characterSprite: {fileID: -1062341636, guid: 42405165cf4950b4a8f837426235b79f, type: 3}
    - characterName: ' '
      sentence: Pasti, Pace. Saya datang jauh-jauh memang untuk melihat keindahan
        ini.
      characterSprite: {fileID: 669661150, guid: c538ff57c18627a4eafe3e9c661704a4, type: 3}
    - characterName: Pace
      sentence: Bagus! Tapi ingat, hati senang boleh, tapi sampah jangan kasih tinggal
        di laut e!
      characterSprite: {fileID: -1062341636, guid: 42405165cf4950b4a8f837426235b79f, type: 3}
  - topicName: The Four King (Legenda)
    lines:
    - characterName: ' '
      sentence: Pace, saya penasaran. Kenapa tempat ini dinamakan ''Raja Ampat''?
      characterSprite: {fileID: 1751235890, guid: c538ff57c18627a4eafe3e9c661704a4, type: 3}
    - characterName: Pace
      sentence: Ah, itu cerita tua, Kaka. Konon dulu ada orang tua temukan tujuh
        telur naga.
      characterSprite: {fileID: -1062341636, guid: 42405165cf4950b4a8f837426235b79f, type: 3}
    - characterName: ' '
      sentence: Tujuh telur? Lalu menetas jadi apa, Pace?
      characterSprite: {fileID: 669661150, guid: c538ff57c18627a4eafe3e9c661704a4, type: 3}
    - characterName: Pace
      sentence: 'Empat jadi raja di pulau besar: Waigeo, Misool, Salawati, dan Batanta.
        Itu makanya tong sebut Empat Raja.'
      characterSprite: {fileID: -1062341636, guid: 42405165cf4950b4a8f837426235b79f, type: 3}
    - characterName: ' '
      sentence: Wah, jadi itu asal mulanya. Lalu tiga telur sisanya?
      characterSprite: {fileID: 669661150, guid: c538ff57c18627a4eafe3e9c661704a4, type: 3}
    - characterName: 
      sentence: Dong bilang jadi batu, hantu, dan wanita. Mistis to? Tapi itulah
        sejarah tong punya tanah.
      characterSprite: {fileID: -1062341636, guid: 42405165cf4950b4a8f837426235b79f, type: 3}
  - topicName: The Walking Shark
    lines:
    - characterName: Pace
      sentence: Kaka, Ko sudah pernah lihat ikan yang kalau jalan pakai kaki?
      characterSprite: {fileID: -1062341636, guid: 42405165cf4950b4a8f837426235b79f, type: 3}
    - characterName: ' '
      sentence: Ikan jalan pakai kaki? Pace jangan bercanda, mana ada ikan begitu.
      characterSprite: {fileID: 669661150, guid: c538ff57c18627a4eafe3e9c661704a4, type: 3}
    - characterName: Pace
      sentence: Hau! Sa tra bercanda. Tong di sini panggil dia Ikan Kalabia, hiu
        yang suka jalan di dasar karang.
      characterSprite: {fileID: -1062341636, guid: 42405165cf4950b4a8f837426235b79f, type: 3}
    - characterName: ' '
      sentence: Luar biasa! Apa dia berbahaya untuk manusia?
      characterSprite: {fileID: 1751235890, guid: c538ff57c18627a4eafe3e9c661704a4, type: 3}
    - characterName: Pace
      sentence: Traada! Dia kecil dan pemalu. Cuma ada di sini saja, traada di tempat
        lain di dunia.
      characterSprite: {fileID: -1062341636, guid: 42405165cf4950b4a8f837426235b79f, type: 3}
  - topicName: Pesan Konservasi
    lines:
    - characterName: ' '
      sentence: Pace, kenapa nelayan di sini sangat menjaga ikan-ikan tertentu?
      characterSprite: {fileID: 669661150, guid: c538ff57c18627a4eafe3e9c661704a4, type: 3}
    - characterName: Pace
      sentence: Karena laut ini tong punya napas, Kaka. Kalau ikan habis, tong anak
        cucu mau makan apa?
      characterSprite: {fileID: -1062341636, guid: 42405165cf4950b4a8f837426235b79f, type: 3}
    - characterName: ' '
      sentence: Saya mengerti. Itu sebabnya saya hanya ingin mencatat data mereka
        lalu melepasnya.
      characterSprite: {fileID: 669661150, guid: c538ff57c18627a4eafe3e9c661704a4, type: 3}
    - characterName: Pace
      sentence: Itu baru namanya penjelajah jempol! Tangkap, pelajari, lalu kasih
        pulang mereka ke laut.
      characterSprite: {fileID: -1062341636, guid: 42405165cf4950b4a8f837426235b79f, type: 3}
    - characterName: ' '
      sentence: Iya Pace, supaya keindahan ini tetap ada sampai kapanpun.
      characterSprite: {fileID: 1751235890, guid: c538ff57c18627a4eafe3e9c661704a4, type: 3}
    - characterName: Pace
      sentence: Mantap! Laut jaga tong, tong jaga laut. Pegang itu kunci e!
      characterSprite: {fileID: -1062341636, guid: 42405165cf4950b4a8f837426235b79f, type: 3}
